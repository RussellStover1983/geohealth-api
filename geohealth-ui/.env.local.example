# =============================================================================
# GeoHealth UI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.

# --- Server-side only (RECOMMENDED for production) ---
# These are used by the BFF proxy (/api/geohealth/...) and never sent to the browser.
GEOHEALTH_API_KEY=your-api-key-here
GEOHEALTH_API_URL=https://geohealth-api-production.up.railway.app

# --- Client-side direct access (optional, for local dev only) ---
# If NEXT_PUBLIC_API_URL is set, the browser calls the API directly (bypasses proxy).
# The API key WILL be visible in browser network tab — only use for local development.
# NEXT_PUBLIC_API_URL=https://geohealth-api-production.up.railway.app
# NEXT_PUBLIC_API_KEY=your-api-key-here
